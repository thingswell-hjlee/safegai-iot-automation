{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://safegai.thingswell.io/contracts/events/safety-decision-v1.schema.json",
  "title": "SafetyDecision",
  "description": "Safety engine decision event. Determines whether equipment should be stopped or allowed to run.",
  "type": "object",
  "required": ["decision_id", "zone_id", "decision", "reason", "timestamp"],
  "properties": {
    "decision_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this decision."
    },
    "zone_id": {
      "type": "string",
      "description": "Zone to which this decision applies."
    },
    "equipment_ids": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Equipment affected by this decision."
    },
    "decision": {
      "type": "string",
      "enum": ["STOP_REQUEST_REQUIRED", "OPERATION_PERMITTED", "HOLD_CURRENT_STATE", "EMERGENCY_STOP"],
      "description": "The safety decision type."
    },
    "reason": {
      "type": "string",
      "description": "Human-readable explanation for the decision."
    },
    "occupancy_state": {
      "type": "string",
      "enum": ["OCCUPIED", "VACANT_PENDING", "VACANT_CONFIRMED", "UNKNOWN", "STALE"],
      "description": "Occupancy state at time of decision."
    },
    "equipment_state": {
      "type": "string",
      "enum": ["RUNNING", "STOPPED", "STOPPING", "STARTING", "FAULT", "OFFLINE"],
      "description": "Equipment state at time of decision."
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Confidence in the decision."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of decision."
    }
  },
  "additionalProperties": false
}
