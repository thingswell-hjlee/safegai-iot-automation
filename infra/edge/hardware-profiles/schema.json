{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thingswell.example/schemas/hardware-profile-v1.json",
  "title": "SafeGAI Hardware Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profileId",
    "hardwareGrade",
    "architecture",
    "minimum",
    "required",
    "qualification"
  ],
  "properties": {
    "profileId": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "hardwareGrade": {
      "const": "SG-EPC-L1"
    },
    "architecture": {
      "const": "amd64"
    },
    "minimum": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cpuCores",
        "memoryMiB",
        "storageGiB",
        "ethernetPorts",
        "usb3Ports"
      ],
      "properties": {
        "cpuCores": {
          "type": "integer",
          "minimum": 4
        },
        "memoryMiB": {
          "type": "integer",
          "minimum": 7600
        },
        "storageGiB": {
          "type": "integer",
          "minimum": 120
        },
        "ethernetPorts": {
          "type": "integer",
          "minimum": 2
        },
        "usb3Ports": {
          "type": "integer",
          "minimum": 2
        }
      }
    },
    "required": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uefi",
        "autoPowerOn",
        "hdmi",
        "fanless",
        "stockUbuntuDrivers",
        "replaceableM2Storage"
      ],
      "properties": {
        "uefi": {
          "const": true
        },
        "autoPowerOn": {
          "const": true
        },
        "hdmi": {
          "const": true
        },
        "fanless": {
          "const": true
        },
        "stockUbuntuDrivers": {
          "const": true
        },
        "replaceableM2Storage": {
          "const": true
        }
      }
    },
    "optional": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tpm2": {
          "type": "boolean"
        },
        "hardwareWatchdog": {
          "type": "boolean"
        },
        "wideDcInput": {
          "type": "boolean"
        }
      }
    },
    "qualification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fourStreamHours",
        "cloudOutageHours",
        "powerCycles",
        "alarmLatencyP95Ms",
        "doLatencyP95Ms"
      ],
      "properties": {
        "fourStreamHours": {
          "type": "integer",
          "minimum": 8
        },
        "cloudOutageHours": {
          "type": "integer",
          "minimum": 72
        },
        "powerCycles": {
          "type": "integer",
          "minimum": 20
        },
        "alarmLatencyP95Ms": {
          "type": "integer",
          "maximum": 1000
        },
        "doLatencyP95Ms": {
          "type": "integer",
          "maximum": 500
        },
        "cpuAverageTargetPercent": {
          "type": "integer",
          "maximum": 35
        },
        "cpuAverageGatePercent": {
          "type": "integer",
          "maximum": 40
        },
        "appMemoryTargetMiB": {
          "type": "integer",
          "maximum": 2048
        },
        "appMemoryGateMiB": {
          "type": "integer",
          "maximum": 3072
        }
      }
    }
  }
}
