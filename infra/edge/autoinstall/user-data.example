#cloud-config
autoinstall:
  version: 1
  locale: ko_KR.UTF-8
  keyboard:
    layout: kr
  identity:
    hostname: safegai-edge
    username: installer
    password: REPLACE_WITH_HASHED_PASSWORD_AT_BUILD_TIME
  ssh:
    install-server: true
    allow-pw: false
    authorized-keys:
      - REPLACE_WITH_PUBLIC_KEY_AT_BUILD_TIME
  storage:
    layout:
      name: lvm
  packages:
    - chrony
    - jq
    - smartmontools
    - nvme-cli
    - sqlite3
    - ca-certificates
  late-commands:
    - curtin in-target --target=/target -- mkdir -p /var/lib/safegai
