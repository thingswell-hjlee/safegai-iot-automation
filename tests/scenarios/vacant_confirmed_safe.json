      { "camera_id": "cam-zone-c-01", "status": "ONLINE" },
      { "camera_id": "cam-zone-c-02", "status": "ONLINE" }
    ]
  },
  "steps": [
    {
      "timestamp": "2024-01-01T14:00:00.000Z",
      "event_type": "occupancy_state",
      "payload": {
        "zone_id": "zone-c",
